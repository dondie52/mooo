# Copy to .env.local and fill in
#
# Optional: "Sign in" without Supabase (sets cookie; middleware allows /dashboard).
# Use only on localhost — never in production.
# NEXT_PUBLIC_DEV_PREVIEW_AUTH=true

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_APP_NAME="Livestock Management & Health Tracking"
BREVO_API_KEY=your-brevo-api-key
